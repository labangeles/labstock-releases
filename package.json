{
    "name": "labstock",
    "productName": "LabStock",
    "version": "1.6.1",
    "description": "Sistema de inventario - Laboratorio Clinico Los Angeles",
    "main": "electron/main.js",
    "scripts": {
        "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && node electron-start.js\"",
        "build": "vite build && electron-builder --win --publish=never",
        "release": "vite build && electron-builder --win --publish=always",
        "build:dir": "vite build && electron-builder --win --dir"
    },
    "build": {
        "appId": "com.labangeles.labstock",
        "productName": "LabStock",
        "copyright": "Laboratorio Clinico Los Angeles",
        "publish": [
            {
                "provider": "github",
                "owner": "labangeles",
                "repo": "labstock-releases",
                "releaseType": "draft"
            }
        ],
        "win": {
            "target": "nsis",
            "requestedExecutionLevel": "asInvoker",
            "icon": "electron/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "warningsAsErrors": false
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            ".env",
            "node_modules/node-machine-id/**/*"
        ],
        "asarUnpack": [
            "node_modules/node-machine-id/**/*"
        ],
        "directories": {
            "output": "dist-electron"
        }
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.108.1",
        "dotenv": "^17.4.2",
        "electron-updater": "^6.8.9",
        "node-machine-id": "^1.1.12",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "recharts": "^3.8.1",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^8.2.2",
        "electron": "^42.4.0",
        "electron-builder": "^26.15.2",
        "vite": "^5.4.0",
        "wait-on": "^7.2.0"
    }
}
